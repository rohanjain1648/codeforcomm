# ── Required for live AI reasoning ───────────────────────────────────────────
# Free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Groq Fallback ────────────────────────────────────────────────
# Free key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: Cloud Translation / Text-to-Speech / Speech-to-Text ───────────
# One API key from a GCP Console project (console.cloud.google.com) with
# these three APIs enabled: Cloud Translation API, Cloud Text-to-Speech API,
# Cloud Speech-to-Text API. Restrict the key to those APIs. Without this key,
# translate/tts/stt endpoints fall back to English text / browser voice.
GOOGLE_CLOUD_API_KEY=your_gcp_api_key_here

# ── Optional: Earth Engine (satellite NDVI + soil moisture) ─────────────────
# Register a service account for Earth Engine at
# https://developers.google.com/earth-engine/guides/service_account
# Download its JSON key and point EE_SERVICE_ACCOUNT_KEY at the file path.
EE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
EE_SERVICE_ACCOUNT_KEY=path/to/service-account-key.json

# ── Optional: Dialogflow ES (conversational SMS/IVR flows) ──────────────────
# Create a Dialogflow ES agent at https://dialogflow.cloud.google.com,
# add intents for: crop_recommendation, weather_alert, health_report,
# subscribe — then set the project ID and a service account with
# Dialogflow API Client role.
DIALOGFLOW_PROJECT_ID=your-dialogflow-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/dialogflow-service-account.json

PORT=8000
